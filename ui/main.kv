BoxLayout:
    orientation: "vertical"

    Label:
        id: verse_label
        text: "Loading..."
        font_size: "20sp"

    BoxLayout:
        size_hint_y: 0.2

        Button:
            text: "English"
            on_press: app.change_lang("en")

        Button:
            text: "Tamil"
            on_press: app.change_lang("ta")