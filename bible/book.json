import json
import os

eng = json.load(open("kjv.json", encoding="utf-8"))
tam = json.load(open("tamil.json", encoding="utf-8"))

os.makedirs("assets/bible", exist_ok=True)

for book in eng:
    data = {}
    for ch in eng[book]:
        data[ch] = {}
        for vs in eng[book][ch]:
            data[ch][vs] = {
                "en": eng[book][ch][vs],
                "ta": tam[book][ch][vs]
            }

    with open(f"assets/bible/{book}.json", "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False)
